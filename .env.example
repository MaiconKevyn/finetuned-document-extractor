# Path to the base model directory (HuggingFace local cache or absolute path)
MODEL_ID=/app/models/Qwen2.5-1.5B-Instruct

# Path to the LoRA adapter directory
ADAPTER_PATH=/app/models/doctune-qwen-1.5b-lora

# HuggingFace cache directory (must be writable by the container user)
HF_HOME=/tmp/hf

# Enable constrained JSON generation via lm-format-enforcer (default: false)
# When true, generation is guaranteed to produce valid JSON matching the schema.
USE_CONSTRAINED_GENERATION=false
